    padding-right: 2px;
    scrollbar-gutter: stable;
  }

  .peoplePanel {
    min-height: 320px;
  }

  .cardHeader,
  .detailHeader {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }

  .cardHeader strong,
  .detailHeader h2 {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .taskCard .cardHeader {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
  }

  .tinyButton {
    min-height: 32px;
    border-radius: 8px;
    padding: 6px 10px;
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 650;
    white-space: nowrap;
  }

  .tinyButton.ghost {
    background: #ffffff;
  }

  .tinyButton.subtle {
    min-height: 28px;
    border-color: #b8dad5;
    background: var(--accent-soft);
    color: var(--accent-strong);
    padding: 4px 8px;
  }

  .iconTinyButton {
    display: inline-grid;
    width: 32px;
    height: 32px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 8px;
    background: #ffffff;
    color: var(--accent-strong);
  }

  .iconTinyButton svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.9;
  }

  .cardActions {
    display: flex;
    justify-content: flex-end;
    padding: 0 12px 12px;
  }

  .personCard strong,
  .taskCard strong {
    color: var(--text);
    line-height: 1.25;
  }

  .personCard span,
  .projectCard span,
  .projectCard small,
  .taskCard span,
  .taskCard small {
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .projectCard.active {
    border-color: #9bcac4;
    background: var(--accent-soft);
  }

  .projectOverviewCard {
    display: grid;
    gap: 16px;
    border-left-width: 5px;
    padding: 20px;
    background: #ffffff;
  }

  .projectOverviewCard.hasInlineDetail {
    grid-template-columns: minmax(0, 1fr) minmax(360px, 400px);
    align-items: start;
  }

  .projectCardMain {
    display: grid;
    min-width: 0;
    gap: 16px;
  }

  .projectOverviewCard.active {
    border-color: #9bcac4;
  }

  .projectOverviewCard.projectStatus-planned {
    border-left-color: #3b82f6;
  }

  .projectOverviewCard.projectStatus-active {
    border-left-color: var(--accent);
  }

  .projectOverviewCard.projectStatus-paused {
    border-left-color: #d99a00;
  }

  .projectOverviewCard.projectStatus-closed {
    border-left-color: #d92d20;
  }

  .projectOverviewHeader {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
  }

  .projectOverviewHeader h2 {
    margin: 4px 0 6px;
    font-size: 1.25rem;
    line-height: 1.25;
    overflow-wrap: anywhere;
  }

  .projectOverviewHeader p {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .projectOverviewHeader p strong {
    color: var(--text);
  }

  .projectOverviewGrid {
    display: grid;
    grid-template-columns: minmax(260px, 0.9fr) minmax(260px, 1.1fr);
    gap: 12px;
  }

  .projectPeopleBlock,
  .projectSummaryBlock,
  .taskGroup {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel-soft);
    padding: 12px;
  }

  .taskGroup.taskStatus-pending,
  .kanbanColumn.taskStatus-pending {
    border-color: #c9d7df;
    background: #f7fafc;
  }

  .taskGroup.taskStatus-in_progress,
  .kanbanColumn.taskStatus-in_progress {
    border-color: #bfdbfe;
    background: #eff6ff;
  }

  .taskGroup.taskStatus-review,
  .kanbanColumn.taskStatus-review {
    border-color: #f2cc75;
    background: #fff8e1;
  }

  .taskGroup.taskStatus-done,
  .kanbanColumn.taskStatus-done {
    border-color: #a7dccb;
    background: #eefbf6;
  }

  .blockHeader,
  .taskGroup header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 10px;
  }

  .blockHeader span,
  .taskGroup header span {
    color: var(--muted);
    font-size: 0.86rem;
  }

  .projectSummaryBlock p {
    color: #34454b;
    font-size: 0.92rem;
  }

  .projectTaskGroups {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .taskGroupList {
    display: grid;
    gap: 8px;
  }

  .taskSummaryRow {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 10px;
    align-items: start;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #ffffff;
    padding: 10px;
  }

  .taskSummaryRow strong {
    display: block;
    color: var(--text);
    line-height: 1.25;
    overflow-wrap: anywhere;
  }

  .taskSummaryRow span {
    display: block;
    margin-top: 4px;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .priorityBadge {
    display: inline-flex !important;
    width: fit-content;
    align-items: center;
    min-height: 24px;
    margin-top: 6px;
    border: 1px solid #d2dee2;
    border-radius: 999px;
    background: #f7fafb;
    color: #50656d;
    font-size: 0.76rem !important;
    font-weight: 700;
    line-height: 1.2 !important;
    padding: 3px 8px;
  }

  .priorityBadge.priority-medium {
    border-color: #bfdbfe;
    background: #eff6ff;
    color: #1d4ed8;
  }

  .priorityBadge.priority-high {
    border-color: #fed7aa;
    background: #fff7ed;
    color: #c2410c;
  }

  .priorityBadge.priority-critical {
    border-color: #f3afa8;
    background: #fff1f0;
    color: #b42318;
  }

  .projectActions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .projectTaskForm {
    margin: 0;
  }

  .compactBoard {
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }

  .projectSelectButton {
    display: grid;
    width: 100%;
    gap: 5px;
    border: 0;
    background: transparent;
    padding: 12px 13px 9px;
    text-align: left;
  }

  .projectCardTitle {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
    align-items: start;
  }

  .statusBadge {
    border: 1px solid #d2dee2;
    border-radius: 999px;
    background: #ffffff;
    color: #50656d;
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1.2;
    padding: 4px 8px;
    white-space: nowrap;
  }

  .statusBadge[data-status="active"] {
    border-color: #9bcac4;
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .statusBadge[data-status="planned"] {
    border-color: #93c5fd;
    background: #eff6ff;
    color: #1d4ed8;
  }

  .statusBadge[data-status="closed"] {
    border-color: #f3afa8;
    background: #fff1f0;
    color: #b42318;
  }

  .statusBadge[data-status="paused"] {
    border-color: #d9c58b;
    background: #fff8e1;
    color: #7a5d00;
  }

  .projectMemberSelect {
    margin: 0 12px 10px;
    width: calc(100% - 24px);
  }

  .projectMemberSelect.inline {
    margin: 10px 0 0;
    width: 100%;
  }

  .helperText {
    margin-top: 10px;
  }

  .memberChipList {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding: 0 12px 10px;
  }

  .memberChipList.spacious {
    padding: 0;
  }

  .memberChip,
  .assigneeChip {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    max-width: 100%;
    border: 1px solid #b8dad5;
    border-radius: 999px;
    background: #ffffff;
    color: var(--accent-strong);
    cursor: grab;
    font-size: 0.8rem;
    font-weight: 650;
    line-height: 1.2;
    padding: 5px 9px;
  }

  .memberChip.inline {
    width: fit-content;
  }

  .countPill {
    border: 1px solid #b8dad5;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    padding: 5px 10px;
    font-size: 0.82rem;
    font-weight: 650;
  }

  .textButton {
    width: fit-content;
    border: 0;
    background: transparent;
    color: var(--accent-strong);
    font-size: 0.84rem;
    font-weight: 650;
    padding: 0;
  }

  .kanbanBoard {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    min-width: 0;
  }

  .kanbanColumn {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 340px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #f7fafb;
  }

  .kanbanColumn header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
    padding: 10px 12px;
  }

  .taskGroup.taskStatus-pending header,
  .kanbanColumn.taskStatus-pending header {
    color: #475569;
  }

  .taskGroup.taskStatus-in_progress header,
  .kanbanColumn.taskStatus-in_progress header {
    color: #1d4ed8;
  }

  .taskGroup.taskStatus-review header,
  .kanbanColumn.taskStatus-review header {
    color: #7a5d00;
  }

  .taskGroup.taskStatus-done header,
  .kanbanColumn.taskStatus-done header {
    color: #047857;
  }

  .kanbanColumn header span {
    color: var(--muted);
  }

  .taskDropZone {
    display: grid;
    align-content: start;
    gap: 10px;
    padding: 10px;
    min-width: 0;
  }

  .taskCard {
    display: grid;
    gap: 8px;
    min-width: 0;
    padding: 11px;
    cursor: grab;
    background: #ffffff;
  }

  .taskMeta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    justify-content: flex-start;
  }

  .emptyText {
    margin: 0;
    color: var(--muted);
    line-height: 1.45;
  }

  .detailPanel {
    position: static;
  }

  .detailDrawerSlot .detailPanel {
    border-color: #b8dad5;
    box-shadow: 0 20px 55px rgba(31, 42, 46, 0.13);
  }

  .detailForm {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .detailForm label,
  .memberRoleRow {
    display: grid;
    gap: 6px;
    color: #304148;
    font-weight: 650;
  }

  .detailForm input,
  .detailForm select,
  .detailForm textarea,
  .memberRoleRow select {
    width: 100%;
    min-height: 40px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: #ffffff;
    color: var(--text);
    font: inherit;
    padding: 9px 11px;
  }

  .detailForm textarea {
    resize: vertical;
  }

  .detailList {
    display: grid;
    gap: 10px;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .memberRoleRow {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel-soft);
    padding: 10px;
  }

  .memberRoleRow span {
    font-weight: 650;
    line-height: 1.3;
  }

  .detailHint {
    margin-top: 14px;
    font-size: 0.86rem;
  }

  .saveFeedback {
    border: 1px solid #a7dccb;
    border-radius: 8px;
    background: #eefbf6;
    color: #047857 !important;
    font-size: 0.9rem;
    font-weight: 650;
    line-height: 1.35 !important;
    padding: 10px 12px;
  }

  .compactFeedback {
    margin: 0;
  }

  dl {
    margin: 0;
    display: grid;
    gap: 12px;
  }

  dt {
    color: var(--muted);
    font-size: 0.78rem;
  }

  dd {
    margin: 2px 0 0;
    overflow-wrap: anywhere;
    color: #27363b;
  }

  @media (max-width: 780px) {
    .shell,
    .shell.sidebarCollapsed {
      grid-template-columns: 1fr;
    }

    .shell.loginOnly {
      display: block;
    }

    .loginLanding {
      grid-template-columns: 1fr;
      align-content: center;
      gap: 18px;
      padding: 18px;
    }

    .loginLanding::before {
      width: 100%;
      height: 32vh;
    }

    .loginHero,
    .loginAccessCard {
      padding: 22px;
    }

    .loginBrandBlock {
      align-items: flex-start;
    }

    .sidebar {
      position: static;
      height: auto;
      border-right: 0;
      border-bottom: 1px solid var(--line);
      padding: 16px;
    }

    .brand {
      padding-bottom: 14px;
    }

    .shell.sidebarCollapsed .brand div,
    .shell.sidebarCollapsed .nav {
      display: grid;
    }

    .nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .main {
      padding: 18px;
    }

    .topbar,
    .session {
      align-items: flex-start;
      flex-direction: column;
    }

    #userLabel {
      max-width: 100%;
      white-space: normal;
    }

    .statusPanel,
    .contentGrid,
    .workspaceLayout,
    .workspaceTopRow,
    .projectOverview.hasDetail,
    .projectOverviewCard.hasInlineDetail,
    .personDirectory.hasDetail,
    .workspaceHero,
    .projectOverviewGrid,
    .projectTaskGroups {
      grid-template-columns: 1fr;
    }

    .personDetailSlot {
      grid-column: auto;
      grid-row: auto;
    }

    .detailDrawerSlot {
      position: fixed;
      inset: auto 10px 10px;
      max-height: min(76vh, 640px);
      overflow: auto;
      z-index: 30;
      border-radius: 12px 12px 8px 8px;
      box-shadow: 0 -18px 60px rgba(31, 42, 46, 0.22);
    }

    .detailDrawerSlot .detailPanel {
      padding: 18px;
    }

    .inlineForm,
    .projectCreateForm,
    .taskSummaryRow {
      grid-template-columns: 1fr;
    }

    .projectOverviewHeader {
      flex-direction: column;
    }

    .projectActions {
      justify-content: flex-start;
    }

    .kanbanBoard {
      grid-template-columns: minmax(220px, 1fr);
      overflow: visible;
    }

    .panelHeader {
      flex-direction: column;
    }

    .metric {
      width: 100%;
    }
  }

  /* ── Catálogo ────────────────────────────────────────────────────── */
  .catalogLayout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr) minmax(340px, 420px);
    gap: 0;
    height: calc(100vh - 64px);
    overflow: hidden;
  }

  .catalogSidebar {
    border-right: 1px solid var(--line);
    padding: 14px 0 18px 14px;
    overflow-y: auto;
    background: var(--panel-soft);
  }

  .catalogSidebarHeader {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-right: 12px;
    margin-bottom: 6px;
  }

  .catalogSidebarHeader .eyebrow { margin: 0; }

  .catalogSyncBadge {
    display: block;
    font-size: 0.75rem;
    color: var(--muted);
    padding: 0 12px 8px 0;
  }

  .catalogSyncBadge.syncing { color: var(--accent-strong); }
  .catalogSyncBadge.none { color: #b45309; }

  .catalogNoCacheMsg {
    padding: 24px 16px;
    color: var(--muted);
    font-size: 0.85rem;
    line-height: 1.55;
  }

  .catalogNoCacheMsg p { margin: 0 0 8px; }

  .catalogDbList {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .catalogDbRow {
    display: flex;
    align-items: center;
    gap: 2px;
    border-radius: 6px;
  }

  .catalogDbRow.active { background: var(--accent-soft); }
  .catalogDbRow:hover { background: var(--line); }

  .catalogDbItem {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
    flex: 1;
    min-width: 0;
    padding: 8px 4px 8px 10px;
    border: none;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    text-align: left;
    color: var(--text);
  }

  .catalogDbRow.active .catalogDbItem { color: var(--accent-strong); font-weight: 600; }

  .catalogSyncDbBtn {
    flex-shrink: 0;
    margin-right: 6px;
    opacity: 0.5;
    font-size: 0.85rem;
  }

  .catalogDbRow:hover .catalogSyncDbBtn { opacity: 1; }

  .catalogDbName { font-size: 0.83rem; word-break: break-all; }
  .catalogDbMeta { font-size: 0.72rem; color: var(--muted); }

  .catalogMain {
    display: flex;
