    gap: 10px;
    margin-bottom: 14px;
  }

  .inlineForm {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .quickForm input,
  .quickForm textarea,
  .inlineForm input,
  .personCreateForm input,
  .personCreateForm textarea,
  .projectCreateForm input,
  .searchInput,
  .projectMemberSelect,
  .taskCard select {
    width: 100%;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: #ffffff;
    color: var(--text);
