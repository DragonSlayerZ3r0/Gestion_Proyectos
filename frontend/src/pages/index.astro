---
const title = "Gestión de Datos";
import "../styles/app.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/icono_gp.png" />
  </head>
  <body>
    <!-- Arranca en "booting" (pantalla neutra de carga), NO en loginOnly: así al
         recargar con sesión activa no destella la página de login mientras se
         valida la sesión — app.ts decide el estado real y quita esta clase. -->
    <div id="app" class="shell booting">
      <aside class="sidebar" aria-label="Módulos">
        <div class="brand">
          <img class="brandMark" src="/icono_gp.png" alt="Logo" />
          <div>
            <strong>Gestión</strong>
            <small>de Datos</small>
          </div>
          <!-- Hamburguesa dibujada (no el carácter ☰): tres barras redondeadas que
               se transforman en flecha "→" al colapsar (morph CSS, ver .burger). -->
          <button id="sidebarToggleButton" class="sidebarToggle" type="button" aria-label="Contraer menú" aria-expanded="true">
            <span class="burger" aria-hidden="true"><span></span><span></span><span></span></span>
          </button>
        </div>
        <nav id="moduleNav" class="nav"></nav>
      </aside>

      <main class="main">
        <section id="loginLanding" class="loginLanding" aria-labelledby="loginLandingTitle">
          <div class="loginHero">
            <div class="loginBrandBlock">
              <img class="loginBrandMark" src="/icono_gp.png" alt="Logo" />
              <div>
                <p class="eyebrow">Acceso interno</p>
                <h1 id="loginLandingTitle">Gestión de Datos</h1>
              </div>
            </div>
            <p class="loginHeroText">Coordinación de proyectos, tareas y personas.<br>Catálogo de datos.</p>
            <div class="loginHeroMeta" aria-label="Información de acceso">
              <span>Ambiente <strong id="loginLandingEnvironment">dev</strong></span>
              <span>Acceso privado</span>
              <span title="Gerencia de Analítica de Datos"><strong>GAD</strong></span>
            </div>
          </div>

          <section class="loginAccessCard" aria-label="Inicio de sesión">
            <p class="eyebrow">Sesión segura</p>
            <h2>Ingresa para continuar</h2>
            <p id="loginLandingMessage">Tus módulos y permisos se cargan después de validar tu identidad.</p>
            <button id="landingLoginButton" class="primaryButton loginAccessButton" type="button">Ingresar</button>
          </section>
        </section>

        <header class="topbar">
          <div>
            <p id="environmentLabel" class="eyebrow">dev</p>
            <h1 id="viewTitle">Inicio</h1>
          </div>
          <div class="session">
            <button id="loginButton" type="button">Ingresar</button>
            <div id="userMenu" class="userMenu" hidden>
              <button
                id="userMenuButton"
                class="userMenuButton"
                type="button"
                aria-haspopup="true"
                aria-expanded="false"
                aria-label="Abrir menú de usuario"
              >
                <svg class="userAvatarIcon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                </svg>
              </button>
              <div id="userMenuDropdown" class="userMenuDropdown" role="menu" hidden>
                <div class="userMenuHeader">
                  <svg class="userAvatarIcon lg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                  </svg>
                  <div class="userMenuIdentity">
                    <span id="userLabel" class="userMenuName">Sin sesión</span>
                    <span id="userEmailLabel" class="userMenuEmail" hidden></span>
                    <span class="userMenuMeta">Sesión activa</span>
                  </div>
                </div>
                <button id="logoutButton" class="userMenuItem" type="button" role="menuitem">
                  <svg class="userMenuItemIcon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z" />
                  </svg>
                  Salir
                </button>
              </div>
            </div>
          </div>
        </header>

        <section id="statusPanel" class="statusPanel">
          <h2>Base técnica</h2>
          <p>Inicia sesión para cargar tu perfil funcional y módulos habilitados.</p>
        </section>

        <section id="contentPanel" class="contentGrid" hidden></section>
      </main>

      <div id="loginDialog" class="dialogBackdrop" hidden>
        <section class="loginDialog" role="dialog" aria-modal="true" aria-labelledby="loginDialogTitle">
          <div class="dialogHeader">
            <div>
              <p class="eyebrow">Acceso seguro</p>
              <h2 id="loginDialogTitle">Iniciar sesión</h2>
            </div>
            <button id="cancelLoginIconButton" class="iconButton" type="button" aria-label="Cancelar inicio de sesión">×</button>
          </div>

          <form id="loginForm" class="loginForm">
            <label>
              Correo electrónico
              <input id="emailInput" name="email" type="email" autocomplete="username" placeholder="nombre@banrural.com.gt" required />
            </label>
            <label>
              Contraseña
              <input id="passwordInput" name="password" type="password" autocomplete="current-password" placeholder="Contraseña" required />
            </label>

            <div id="newPasswordFields" class="newPasswordFields" hidden>
              <p>Define una contraseña nueva para completar el primer ingreso.</p>
              <label>
                Nueva contraseña
                <input id="newPasswordInput" name="newPassword" type="password" autocomplete="new-password" placeholder="Nueva contraseña" />
              </label>
            </div>

            <p id="loginMessage" class="loginMessage" aria-live="polite"></p>

            <div class="dialogActions">
              <button id="cancelLoginButton" class="secondaryButton" type="button">Cancelar</button>
              <button id="submitLoginButton" class="primaryButton" type="submit">Ingresar</button>
            </div>
          </form>
        </section>
      </div>
    </div>

    <script>
      import "../scripts/app.ts";
    </script>
  </body>
</html>

