    align-items: start;
  }

  .workspaceTopRow > .panel {
    max-height: 360px;
    overflow: auto;
  }

  .workspaceTopRow > .projectsPanel:only-child {
    grid-column: 1 / -1;
  }

  .sectionHeader {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 14px;
  }

  .sectionHeader h2 {
    margin: 4px 0 0;
  }

  .sectionActions {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: flex-end;
  }

  .quickForm,
