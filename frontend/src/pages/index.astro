  }

  .personDetailSlot {
    grid-column: 2;
    grid-row: 1 / span 2;
  }

  .peopleStrip {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 8px;
    max-height: 116px;
