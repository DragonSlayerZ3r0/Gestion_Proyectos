    flex-wrap: wrap;
    gap: 7px;
    margin: -2px 0 12px;
  }

  .filterChip {
    min-height: 30px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: #ffffff;
    color: #50656d;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 650;
    padding: 5px 10px;
  }

  .filterChip.active {
    border-color: #9bcac4;
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  .filterChip[data-project-status-filter="planned"].active {
    border-color: #93c5fd;
    background: #eff6ff;
    color: #1d4ed8;
  }

  .filterChip[data-project-status-filter="paused"].active {
    border-color: #f2cc75;
    background: #fff8e1;
    color: #7a5d00;
  }

  .filterChip[data-project-status-filter="closed"].active {
    border-color: #f3afa8;
    background: #fff1f0;
    color: #b42318;
  }

  .personCard,
  .projectCard,
  .taskCard,
  .projectOverviewCard {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel-soft);
    color: #34454b;
  }

  .personCard.selected,
  .projectCard.selected,
  .taskCard.selected,
  .projectOverviewCard.selected {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.12);
  }

  .personCard {
    display: block;
    padding: 8px 10px;
    cursor: grab;
  }

  .personDirectory {
    display: grid;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel-soft);
    padding: 10px 12px;
  }

  .personDirectory.hasDetail {
    grid-template-columns: minmax(0, 1fr) minmax(340px, 390px);
    align-items: start;
  }

  .personDirectory > .blockHeader,
  .personDirectory > .peopleStrip {
    min-width: 0;
  }

  .personDirectory.hasDetail > .blockHeader,
  .personDirectory.hasDetail > .peopleStrip {
