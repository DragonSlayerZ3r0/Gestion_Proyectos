---
const title = "Gestión de Proyectos";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div id="app" class="shell">
      <aside class="sidebar" aria-label="Módulos">
        <div class="brand">
          <span class="brandMark">GP</span>
          <div>
            <strong>Gestión</strong>
            <small>Proyectos</small>
          </div>
        </div>
        <nav id="moduleNav" class="nav"></nav>
      </aside>

      <main class="main">
        <header class="topbar">
          <div>
            <p id="environmentLabel" class="eyebrow">dev</p>
            <h1 id="viewTitle">Inicio</h1>
          </div>
          <div class="session">
            <span id="userLabel">Sin sesión</span>
            <button id="loginButton" type="button">Ingresar</button>
            <button id="logoutButton" type="button" hidden>Salir</button>
          </div>
        </header>

        <section id="statusPanel" class="statusPanel">
          <h2>Base técnica</h2>
          <p>Inicia sesión para cargar tu perfil funcional y módulos habilitados.</p>
        </section>

        <section id="contentPanel" class="contentGrid" hidden></section>
      </main>
    </div>

    <script>
      // @ts-nocheck
      import { UserManager, WebStorageStateStore } from "oidc-client-ts";

      const defaultModules = [
        { key: "home", label: "Inicio" },
        { key: "projects", label: "Proyectos" },
        { key: "tasks", label: "Tareas" },
        { key: "catalog", label: "Catálogo" },
        { key: "admin", label: "Administración" }
      ];

      const viewCopy = {
        home: {
          title: "Inicio",
          eyebrow: "Vista general",
          body: "Resumen operativo de proyectos, tareas y accesos habilitados.",
          metricLabel: "Elementos activos",
          metricValue: "5",
          items: ["Proyectos recientes", "Tareas asignadas", "Accesos disponibles"]
        },
        projects: {
          title: "Proyectos",
          eyebrow: "Gestión",
          body: "Espacio reservado para crear, consultar y administrar proyectos.",
          metricLabel: "Vista preparada",
          metricValue: "Base",
          items: ["Listado de proyectos", "Detalle operativo", "Miembros y responsables"]
        },
        tasks: {
          title: "Tareas",
          eyebrow: "Seguimiento",
          body: "Seguimiento simple de tareas por estado, prioridad y responsable.",
          metricLabel: "Estados base",
          metricValue: "4",
          items: ["Pendiente", "En progreso", "En revisión", "Completada"]
        },
        catalog: {
          title: "Catálogo",
          eyebrow: "Data Lake",
          body: "Exploración controlada de Glue Catalog con contexto funcional.",
          metricLabel: "Acceso",
          metricValue: "Controlado",
          items: ["Bases permitidas", "Tablas documentadas", "Preview limitado"]
        },
        admin: {
          title: "Administración",
          eyebrow: "Gobierno funcional",
          body: "Gestión inicial de usuarios, módulos habilitados y auditoría.",
          metricLabel: "Controles",
          metricValue: "3",
          items: ["Usuarios funcionales", "Módulos habilitados", "Auditoría"]
        }
      };

      const state = {
        config: null,
        manager: null,
        user: null,
        profile: null,
        activeModule: "home"
      };

      const elements = {
        moduleNav: document.querySelector("#moduleNav"),
        loginButton: document.querySelector("#loginButton"),
        logoutButton: document.querySelector("#logoutButton"),
        userLabel: document.querySelector("#userLabel"),
        environmentLabel: document.querySelector("#environmentLabel"),
        statusPanel: document.querySelector("#statusPanel"),
        contentPanel: document.querySelector("#contentPanel"),
        viewTitle: document.querySelector("#viewTitle")
      };

      boot();

      async function boot() {
        renderDefaultNav();
        state.config = await loadConfig();
        elements.environmentLabel.textContent = state.config.environment || "dev";

        if (!hasAuthConfig(state.config)) {
          renderStatus("Configuración pendiente", "Falta completar config.json con Cognito y API Gateway.");
          return;
        }

        state.manager = new UserManager({
          authority: `https://cognito-idp.${state.config.region}.amazonaws.com/${state.config.cognitoUserPoolId}`,
          client_id: state.config.cognitoClientId,
          redirect_uri: `${window.location.origin}/`,
          post_logout_redirect_uri: `${window.location.origin}/`,
          response_type: "code",
          scope: "openid email profile",
          userStore: new WebStorageStateStore({ store: window.sessionStorage }),
          automaticSilentRenew: false
        });

        elements.loginButton.addEventListener("click", () => state.manager.signinRedirect());
        elements.logoutButton.addEventListener("click", () => state.manager.signoutRedirect());

        if (window.location.search.includes("code=") && window.location.search.includes("state=")) {
          await state.manager.signinCallback();
          window.history.replaceState({}, document.title, window.location.pathname);
        }

        state.user = await state.manager.getUser();
        if (!state.user || state.user.expired) {
          renderLoggedOut();
          return;
        }

        await loadMe();
      }

      async function loadConfig() {
        const response = await fetch("/config.json", { cache: "no-store" });
        return response.json();
      }

      function hasAuthConfig(config) {
        return Boolean(config.apiBaseUrl && config.region && config.cognitoUserPoolId && config.cognitoClientId);
      }

      async function loadMe() {
        const response = await fetch(`${state.config.apiBaseUrl}api/me`, {
          headers: {
            authorization: `Bearer ${state.user.access_token}`
          }
        });
        const payload = await response.json();

        if (!response.ok || !payload.ok) {
          renderStatus("Acceso pendiente", payload.error?.message || "No fue posible cargar tu perfil.");
          return;
        }

        state.profile = payload.data;
        state.activeModule = payload.data.modules?.[0]?.key || "home";
        renderApp();
      }

      function renderLoggedOut() {
        elements.loginButton.hidden = false;
        elements.logoutButton.hidden = true;
        elements.userLabel.textContent = "Sin sesión";
        renderStatus(
          "Acceso requerido",
          "Inicia sesión para cargar tu perfil funcional, validar permisos y mostrar solo los módulos que tienes habilitados."
        );
      }

      function renderApp() {
        elements.loginButton.hidden = true;
        elements.logoutButton.hidden = false;
        elements.userLabel.textContent = state.profile.user.email;
        elements.environmentLabel.textContent = state.profile.environment;
        renderNav();
        renderModule(state.activeModule);
      }

      function renderNav() {
        elements.moduleNav.innerHTML = "";
        for (const module of state.profile.modules) {
          const button = document.createElement("button");
          button.type = "button";
          button.textContent = module.label;
          button.className = module.key === state.activeModule ? "navItem active" : "navItem";
          button.addEventListener("click", () => {
            state.activeModule = module.key;
            renderApp();
          });
          elements.moduleNav.append(button);
        }
      }

      function renderDefaultNav() {
        elements.moduleNav.innerHTML = "";
        for (const module of defaultModules) {
          const button = document.createElement("button");
          button.type = "button";
          button.textContent = module.label;
          button.className = module.key === "home" ? "navItem active" : "navItem muted";
          button.setAttribute("aria-disabled", "true");
          elements.moduleNav.append(button);
        }
      }

      function renderModule(moduleKey) {
        const copy = viewCopy[moduleKey] || viewCopy.home;
        const items = copy.items.map((item) => `<li>${item}</li>`).join("");
        elements.statusPanel.hidden = true;
        elements.contentPanel.hidden = false;
        elements.viewTitle.textContent = copy.title;
        elements.contentPanel.innerHTML = `
          <article class="panel modulePanel">
            <p class="eyebrow">${copy.eyebrow}</p>
            <div class="panelHeader">
              <div>
                <h2>${copy.title}</h2>
                <p>${copy.body}</p>
              </div>
              <div class="metric">
                <strong>${copy.metricValue}</strong>
                <span>${copy.metricLabel}</span>
              </div>
            </div>
            <ul class="workList">${items}</ul>
          </article>
          <article class="panel profilePanel">
            <h2>Perfil</h2>
            <dl>
              <div><dt>Usuario</dt><dd>${state.profile.user.email}</dd></div>
              <div><dt>Perfiles</dt><dd>${state.profile.user.roles.join(", ")}</dd></div>
              <div><dt>Ambiente</dt><dd>${state.profile.environment}</dd></div>
            </dl>
          </article>
          <article class="panel actionPanel">
            <h2>Siguientes acciones</h2>
            <ul class="workList">
              <li>Validar el primer inicio de sesión con Cognito.</li>
              <li>Confirmar módulos visibles según permisos.</li>
              <li>Priorizar el primer flujo operativo.</li>
            </ul>
          </article>
        `;
      }

      function renderStatus(title, message) {
        elements.statusPanel.hidden = false;
        elements.contentPanel.hidden = true;
        elements.viewTitle.textContent = title;
        elements.statusPanel.innerHTML = `
          <div>
            <p class="eyebrow">Plataforma interna</p>
            <h2>${title}</h2>
            <p>${message}</p>
          </div>
          <ul class="statusList">
            <li>Autenticación centralizada con Cognito.</li>
            <li>Permisos funcionales desde DynamoDB.</li>
            <li>Frontend privado servido por CloudFront.</li>
          </ul>
        `;
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #eef3f4;
    --panel: #ffffff;
    --panel-soft: #f8fbfb;
    --line: #d8e1e4;
    --line-strong: #c0ced2;
    --text: #1b272b;
    --muted: #62737a;
    --accent: #0f766e;
    --accent-strong: #115e59;
    --accent-soft: #e3f3f0;
    --focus: #2563eb;
    --shadow: 0 18px 50px rgba(31, 42, 46, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  button {
    border: 1px solid var(--line);
    background: var(--panel);
    color: var(--text);
    cursor: pointer;
    font: inherit;
    transition: background 140ms ease, border-color 140ms ease, color 140ms ease, transform 140ms ease;
  }

  button:hover:not(:disabled) {
    border-color: var(--line-strong);
    transform: translateY(-1px);
  }

  button:focus-visible {
    outline: 3px solid rgba(37, 99, 235, 0.25);
    outline-offset: 2px;
  }

  button:disabled {
    cursor: default;
  }

  .shell {
    display: grid;
    grid-template-columns: 276px minmax(0, 1fr);
    min-height: 100vh;
  }

  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    border-right: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.92);
    padding: 22px 16px;
  }

  .brand {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 2px 6px 24px;
  }

  .brandMark {
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border-radius: 8px;
    background: var(--accent);
    color: #ffffff;
    font-weight: 700;
  }

  .brand strong {
    display: block;
    line-height: 1.1;
  }

  .brand small,
  .eyebrow {
    display: block;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .nav {
    display: grid;
    gap: 8px;
  }

  .navItem {
    width: 100%;
    border-radius: 8px;
    padding: 11px 12px;
    text-align: left;
    color: #34454b;
  }

  .navItem.active {
    border-color: #9bcac4;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-weight: 650;
  }

  .navItem.muted {
    color: #829097;
    background: #f9fbfb;
  }

  .main {
    width: min(1180px, 100%);
    padding: 28px;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: center;
    margin-bottom: 22px;
  }

  .topbar h1 {
    margin: 4px 0 0;
    font-size: 2rem;
    line-height: 1.15;
  }

  .session {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    min-width: 0;
  }

  .session button {
    border-radius: 8px;
    min-height: 40px;
    padding: 9px 14px;
    font-weight: 650;
  }

  #userLabel {
    max-width: 320px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #loginButton {
    border-color: var(--accent);
    background: var(--accent);
    color: #ffffff;
  }

  .statusPanel,
  .panel {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    box-shadow: var(--shadow);
  }

  .statusPanel {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(260px, 0.7fr);
    gap: 24px;
    max-width: 980px;
    padding: 28px;
  }

  .panel {
    padding: 24px;
  }

  .statusPanel h2,
  .panel h2 {
    margin: 0 0 8px;
    font-size: 1.15rem;
    line-height: 1.25;
  }

  .statusPanel p,
  .panel p {
    margin: 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .contentGrid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr);
    gap: 16px;
    align-items: start;
  }

  .modulePanel {
    min-height: 300px;
  }

  .actionPanel {
    grid-column: 1 / -1;
  }

  .panelHeader {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: flex-start;
    margin-top: 6px;
  }

  .metric {
    min-width: 138px;
    border: 1px solid #b8dad5;
    border-radius: 8px;
    background: var(--accent-soft);
    padding: 14px;
    color: var(--accent-strong);
  }

  .metric strong {
    display: block;
    font-size: 1.45rem;
    line-height: 1.1;
  }

  .metric span {
    display: block;
    margin-top: 5px;
    color: #3f6965;
    font-size: 0.8rem;
  }

  .workList,
  .statusList {
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 10px;
  }

  .workList li,
  .statusList li {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel-soft);
    padding: 11px 12px;
    color: #34454b;
    line-height: 1.4;
  }

  .statusList {
    margin-top: 0;
  }

  dl {
    margin: 0;
    display: grid;
    gap: 12px;
  }

  dt {
    color: var(--muted);
    font-size: 0.78rem;
  }

  dd {
    margin: 2px 0 0;
    overflow-wrap: anywhere;
    color: #27363b;
  }

  @media (max-width: 780px) {
    .shell {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      height: auto;
      border-right: 0;
      border-bottom: 1px solid var(--line);
      padding: 16px;
    }

    .brand {
      padding-bottom: 14px;
    }

    .nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .main {
      padding: 18px;
    }

    .topbar,
    .session {
      align-items: flex-start;
      flex-direction: column;
    }

    #userLabel {
      max-width: 100%;
      white-space: normal;
    }

    .statusPanel,
    .contentGrid {
      grid-template-columns: 1fr;
    }

    .panelHeader {
      flex-direction: column;
    }

    .metric {
      width: 100%;
    }
  }
</style>
